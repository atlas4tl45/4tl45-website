<section class="hero">
  <div class="container">
    <div class="hero-content">
      <p class="section-label">Custom Software & Web Solutions — Terre Haute, IN</p>
      <h1>We build the software<br />your business runs on</h1>
      <p class="hero-sub">
        More customers, a site that looks as good as your work, and tools that
        save you hours every week. ATLAS builds custom software and websites
        for small businesses in Terre Haute and the Wabash Valley — no
        templates, no bloat, just results.
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Start a Project</a>
        <a href="#services" class="btn btn-secondary">See What We Build</a>
      </div>
    </div>
  </div>
  <div class="hero-glow" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    padding: 10rem 0 6rem;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 720px;
  }

  .hero-sub {
    font-size: 1.125rem;
    line-height: 1.7;
    margin-top: 1.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .hero-glow {
    position: absolute;
    top: -40%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--color-accent-subtle) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
</style>
