---
const projects = [
  {
    name: 'Sparkle Pools',
    url: 'https://mysparklepools.com',
    description:
      'Built for a local pool service company in the Wabash Valley — a modern site designed to generate leads and showcase their work.',
    tags: ['Website', 'Design', 'Development'],
  },
  {
    name: 'Dusty Renovations',
    url: 'https://dustyrenovations.com',
    description:
      'A clean, professional site for a renovation contractor — built to establish credibility and drive inquiries.',
    tags: ['Website', 'Design', 'Development'],
  },
];
---

<section id="work" class="section">
  <div class="container">
    <p class="section-label">Our Work</p>
    <h2>Projects we've shipped</h2>
    <div class="work-grid">
      {
        projects.map((project) => (
          <a href={project.url} target="_blank" rel="noopener noreferrer" class="work-card">
            <div class="work-card-content">
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              <div class="work-tags">
                {project.tags.map((tag) => (
                  <span class="work-tag">{tag}</span>
                ))}
              </div>
            </div>
            <span class="work-arrow">&rarr;</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .work-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .work-card {
    display: flex;
    justify-content: space-between;
    align-items: start;
    padding: 2rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: border-color var(--transition), transform var(--transition);
  }

  .work-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .work-card-content {
    flex: 1;
  }

  .work-arrow {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    transition: color var(--transition), transform var(--transition);
    margin-left: 1.5rem;
    margin-top: 0.25rem;
  }

  .work-card:hover .work-arrow {
    color: var(--color-accent);
    transform: translateX(4px);
  }

  h3 {
    margin-bottom: 0.75rem;
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }

  .work-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.25rem 0.625rem;
    background: var(--color-accent-subtle);
    color: var(--color-accent);
    border-radius: 4px;
  }
</style>
